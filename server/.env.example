# DATABASE_URL=postgresql://taskai_user:pass123@localhost:5432/taskai

# Supabase — Transaction pooler (6543, pool_mode=transaction).
# Логин вида postgres.<project_ref>, хост и порт — из Dashboard → Connect → Transaction pool.
# Пароль: Project Settings → Database → Database password (спецсимволы в пароле — URL-encode).
# Пример:
# DATABASE_URL=postgresql://postgres.xxxxx:ПАРОЛЬ@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

JWT_SECRET=my_super_long_random_secret_!@_for_taskai_2026
FRONTEND_ORIGIN=http://localhost:8080
PORT=4000
